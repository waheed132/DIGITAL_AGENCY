# =============================================================================
# LOCAL — copy this file to `.env` on your PC for `npm run dev`
# =============================================================================
# Laravel must be reachable here (e.g. php artisan serve → port 8000).
# No trailing slash. Do not add `/api` — routes already use /api/...

VITE_API_URL=http://127.0.0.1:8000

# =============================================================================
# LIVE — set on Vercel (Project → Settings → Environment Variables), not in git
# =============================================================================
# Same variable name. Value = Railway **public HTTPS URL** of your Laravel app only.
# In Vercel: Name = VITE_API_URL, Value = https://....up.railway.app only — do NOT paste
# "VITE_API_URL=https://..." into the value box (that breaks login with 405 on the frontend).
# Redeploy Vercel after changing VITE_* (baked in at build time).
#
# VITE_API_URL=https://your-laravel-service.up.railway.app
#
# Optional: log failed API responses in the browser console (including production builds).
# VITE_DEBUG_API=true
